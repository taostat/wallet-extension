{
  "extends": "@taostats-wallet/tsconfig/es6-react.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": "src",
    "moduleResolution": "bundler",
    "paths": {
      "@common": ["./common"],
      "@common/*": ["./common/*"],
      "@taostats": ["./@taostats"],
      "@taostats/*": ["./@taostats/*"],
      "@ui": ["./ui"],
      "@ui/*": ["./ui/*"],
      "@tests": ["./tests"],
      "@tests/*": ["./tests/*"]
    }
  },
  "include": ["i18next-parser.config.cjs", "src", "**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/.*/", "**/*.spec.ts", "**/*.test.ts"]
}
