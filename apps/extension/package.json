  "scripts": {
    "start": "rm -rf dist && webpack --config webpack/webpack.dev.js --watch",
    "dev": "rm -rf dist && webpack --config webpack/webpack.dev.js --watch --env build=dev",
    "dev:firefox": "rm -rf dist && BROWSER=firefox webpack --config webpack/webpack.dev.js --watch --env build=dev",
    "build:extension": "rm -rf dist && webpack --config webpack/webpack.prod.js --env build=qa",
    "build:extension:firefox": "rm -rf dist && BROWSER=firefox webpack --config webpack/webpack.prod.js --env build=qa",
    "build:extension:ci": "rm -rf dist && webpack --config webpack/webpack.prod.js --env build=ci",
    "build:extension:ci:firefox": "rm -rf dist && BROWSER=firefox webpack --config webpack/webpack.prod.js --env build=ci",
    "build:extension:canary": "rm -rf dist && webpack --config webpack/webpack.prod.js --env build=canary",
    "build:extension:canary:firefox": "rm -rf dist && BROWSER=firefox webpack --config webpack/webpack.prod.js --env build=canary",
    "build:extension:prod": "rm -rf dist && webpack --config webpack/webpack.prod.js --env build=production",
    "build:extension:prod:firefox": "rm -rf dist && BROWSER=firefox webpack --config webpack/webpack.prod.js --env build=production",
    "test": "PORT_PREFIX=taostats jest --maxWorkers=50%",
    "test:watch": "PORT_PREFIX=taostats jest --watch",
    "lint": "eslint . --max-warnings 0 --ext ts,tsx",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "clean": "rm -rf dist .turbo node_modules coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@taostats-wallet/eslint-config/react"
    ]
  }
