{
  "name": "talisman",
  "version": "0.0.0",
  "license": "GPL-3.0-or-later",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.16.1+sha512.0e155aa2629db8672b49e8475da6226aa4bdea85fdcdfdc15350874946d4f3c91faaf64cbdc4a5d1ab8002f473d5c3fcedcd197989cf0390f9badd3c04678706",
  "scripts": {
    "postinstall": "preconstruct dev && pnpm papi:once",
    "prepare": "husky",
    "preconstruct:dev": "preconstruct dev",
    "preconstruct:fix": "preconstruct fix",
    "papi": "papi",
    "papi:once": "test -d .papi/descriptors/dist && echo 'existing papi descriptors found! run \"pnpm papi\" to regenerate them' || papi",
    "papi:update": "papi update",
    "chore:format": "prettier --write \"{apps,config,packages}/**/src/**/*.{ts,tsx,js,jsx,css,scss,html,md,json}\"",
    "chore:update-translations": "pnpm run --filter extension chore:update-translations",
    "chore:update:translations": "pnpm chore:update-translations",
    "chore:download-translations": "pnpm run --filter extension chore:download-translations",
    "update:translations": "pnpm chore:update-translations",
    "chore:generate-init-data": "pnpm run --filter @talismn/chaindata-provider chore:generate-init-data",
    "generate-init-data": "pnpm chore:generate-init-data",
    "chore:prepare-release": "pnpm generate-init-data && pnpm chore:download-translations",
    "dev": "pnpm dev:extension",
    "dev:firefox": "pnpm dev:extension:firefox",
    "dev:*": "concurrently --prefix \"{name}\" --prefix-colors auto \"pnpm:dev:*\"",
    "dev:balances-demo": "pnpm run --filter balances-demo dev",
    "dev:extension": "preconstruct dev && pnpm run --filter extension dev",
    "dev:extension:firefox": "preconstruct dev && pnpm run --filter extension dev:firefox",
    "build": "turbo run build",
    "build:packages": "NODE_OPTIONS=--max_old_space_size=8192 preconstruct build",
    "build:extension": "turbo run build:extension",
    "build:extension:firefox": "turbo run build:extension:firefox",
    "build:extension:ci": "turbo run build:extension:ci",
    "build:extension:ci:firefox": "turbo run build:extension:ci:firefox",
    "build:extension:canary": "turbo run build:extension:canary",
    "build:extension:canary:firefox": "turbo run build:extension:canary:firefox",
    "build:extension:prod": "turbo run build:extension:prod",
    "build:extension:prod:firefox": "turbo run build:extension:prod:firefox",
    "build:review:firefox": "bash scripts/build-review-firefox.sh",
    "lint": "pnpm run -r --parallel lint",
    "test": "pnpm run -r --parallel test",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:e2e:debug": "pnpm exec playwright test --debug",
    "test:e2e:trace": "pnpm exec playwright test --trace on && pnpm exec playwright show-report",
    "test:e2e:stress": "pnpm exec playwright test --repeat-each=20 --workers 1 --trace on",
    "clean": "pnpm run -r --parallel clean & rm -rf dist .turbo node_modules & wait"
  },
  "dependencies": {
    "polkadot-api": "1.13.1"
  },
  "devDependencies": {
    "@alectalisman/preconstruct-cli": "2.3.0-e",
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@playwright/test": "^1.51.1",
    "@talismn/eslint-config": "workspace:*",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^24.5.1",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "concurrently": "^9.0.1",
    "eslint": "8.57.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "ts-loader": "9.5.1",
    "turbo": "2.2.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "peerDependencyRules": {
      "ignoreMissing": [
        "react-native",
        "eciesjs"
