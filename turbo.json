{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": [
    "EVM_LOGPROXY",
    "MEASURE_WEBPACK_SPEED",
    "NODE_DEBUG",
    "NODE_ENV",
    "NODE_OPTIONS",
    "PASSWORD",
    "PORT_PREFIX",
    "POSTHOG_AUTH_TOKEN",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_DSN",
    "SIMPLE_LOCALIZE_API_KEY",
    "SIMPLE_LOCALIZE_PROJECT_TOKEN",
    "SUPPORTED_LANGUAGES",
    "TEST_MNEMONIC",
    "USE_ONE_DIST_DIR",
    "npm_package_version"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["//#build:packages", "^build"],
      "outputs": ["dist/**"],
      "cache": false
    },
    "//#build:packages": {
      "dependsOn": [],
      "outputs": ["packages/**/dist/**/*"]
    },
    "build:extension": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    },
    "build:extension:firefox": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    },
    "build:extension:ci": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    },
    "build:extension:ci:firefox": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    },
    "build:extension:canary": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    },
    "build:extension:canary:firefox": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    },
    "build:extension:prod": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    },
    "build:extension:prod:firefox": {
      "dependsOn": ["//#build:packages"],
      "outputs": ["dist/**"]
    }
  }
}
